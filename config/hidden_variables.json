    "market_saturation_threshold": "Monthly demand cap before diminishing returns",
    "price_sensitivity": "0-1. Higher = customers more price-conscious",
    "social_media_buzz": "0-1. Higher = more viral, amplifies hype events",
    "competitor_pressure": "0-1. Higher = more competitor activity, reduces demand up to 15%",
    "brand_loyalty": "0-1. Higher = customers stick despite alternatives"
  },
  "_composite_score_guide": {
    "formula": "0.40 × norm(base_demand) + 0.25 × norm(social_media_buzz) + 0.20 × norm(brand_loyalty) + 0.15 × norm(trend_monthly_pct)",
    "grading": "Top 20% = A, Next 30% = B, Bottom 50% = C",
    "weights": {
      "base_daily_demand": 0.4,
      "social_media_buzz": 0.25,
      "brand_loyalty": 0.2,
      "trend_monthly_pct": 0.15
    }
